# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicit text files
*.py        text diff=python
*.toml      text
*.md        text
*.yml       text
*.yaml      text
*.json      text
*.sh        text eol=lf

# Binary files
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.woff      binary
*.woff2     binary

# Linguist overrides
docs/**     linguist-documentation
tests/**    linguist-detectable=true

# Avoid merge conflicts in lock files
uv.lock     merge=ours
